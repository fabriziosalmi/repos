---
/**
 * CompactRepo.astro
 * Single-line repo entry for supporting project lists within domain sections.
 */
interface Props {
  repo: Record<string, any>;
}

const { repo } = Astro.props;

const LANG_COLORS: Record<string, string> = {
  Python: '#3572A5', Go: '#00ADD8', Rust: '#dea584',
  TypeScript: '#3178c6', JavaScript: '#f1e05a', Swift: '#F05138',
  HTML: '#e34c26', Shell: '#89e051', Ruby: '#701516', CSS: '#563d7c',
};

const langColor = LANG_COLORS[repo.language] || '#6b7280';
const stars = repo.stars || 0;
---

<a
  href={repo.url}
  target="_blank"
  rel="noopener noreferrer"
  class="group flex items-center gap-3 py-2.5 px-1 -mx-1 rounded hover:bg-surface/60 transition-colors"
>
  <!-- Language dot -->
  {repo.language && (
    <span class="w-2 h-2 rounded-full flex-shrink-0" style={`background-color: ${langColor}`}></span>
  )}
  {!repo.language && (
    <span class="w-2 h-2 rounded-full flex-shrink-0 bg-textSubtle/30"></span>
  )}

  <!-- Name -->
  <span class="font-mono text-sm text-textMuted group-hover:text-text transition-colors truncate min-w-0 flex-1">
    {repo.name}
  </span>

  <!-- Description (hidden on small screens) -->
  <span class="hidden md:block text-xs text-textSubtle truncate max-w-[280px] lg:max-w-[360px]">
    {repo.description || ''}
  </span>

  <!-- Stars -->
  {stars > 0 ? (
    <span class="flex items-center gap-1 text-xs text-accent/80 font-mono flex-shrink-0 tabular-nums">
      <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
      {stars.toLocaleString()}
    </span>
  ) : (
    <span class="text-[9px] uppercase tracking-widest text-accent border border-accent/30 rounded px-1 py-0.5 flex-shrink-0">New</span>
  )}
</a>
