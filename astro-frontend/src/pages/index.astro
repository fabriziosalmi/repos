          flagshipCount={0}
        />
      </div>
    )}

    <!-- ─── Other Projects ───────────────────────────────────── -->
    {otherRepos.length > 0 && (
      <div class="mb-14 md:mb-18">
        <DomainSection
          title="Other Projects"
          description="Utilities, experiments, and cross-domain tooling."
          repos={otherRepos}
          flagshipCount={0}
        />
      </div>
    )}

    <!-- ─── Competency ───────────────────────────────────────── -->
    <section class="mb-14 md:mb-18 py-8 border-t border-b border-surfaceBorder">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <div class="text-2xl font-bold text-text tabular-nums">{totalStars.toLocaleString()}</div>
          <div class="text-xs text-textMuted uppercase tracking-wider mt-1">Stars</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-text tabular-nums">{totalRepos}</div>
          <div class="text-xs text-textMuted uppercase tracking-wider mt-1">Repositories</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-text tabular-nums">{totalForks.toLocaleString()}</div>
          <div class="text-xs text-textMuted uppercase tracking-wider mt-1">Forks</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-text tabular-nums">{topLangs.length}</div>
          <div class="text-xs text-textMuted uppercase tracking-wider mt-1">Languages</div>
        </div>
      </div>
      <div class="flex flex-wrap justify-center gap-x-4 gap-y-1 mt-6">
        {topLangs.map(([lang, count]) => (
          <span class="text-xs text-textSubtle">
            {lang} <span class="text-textMuted font-mono">({count})</span>
          </span>
        ))}
        {otherLangsCount > 0 && (
          <span class="text-xs text-textSubtle">
            Other <span class="text-textMuted font-mono">({otherLangsCount})</span>
          </span>
        )}
      </div>
      {!topLangs.some(([lang]) => lang === 'Rust') && (
        <div class="text-center mt-4">
          <p class="text-xs text-textMuted italic">
            Rust used in flagship projects (ZION, AIMP). Go used for production tooling. Python for ML and automation.
          </p>
        </div>
      )}
    </section>

    <!-- ─── Footer ───────────────────────────────────────────── -->
    <footer class="pt-8 border-t border-surfaceBorder">
      <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4 mb-6">
        <div class="flex items-center gap-5">
          <a href="https://github.com/fabriziosalmi" target="_blank" rel="noopener noreferrer" class="text-xs text-textSubtle hover:text-textMuted transition-colors uppercase tracking-wider">GitHub</a>
          <a href="https://linkedin.com/in/fabriziosalmi" target="_blank" rel="noopener noreferrer" class="text-xs text-textSubtle hover:text-textMuted transition-colors uppercase tracking-wider">LinkedIn</a>
          <a href="https://www.researchgate.net/profile/Fabrizio-Salmi/publications" target="_blank" rel="noopener noreferrer" class="text-xs text-textSubtle hover:text-textMuted transition-colors uppercase tracking-wider">ResearchGate</a>
        </div>
        <p class="text-xs text-textSubtle">
          European open-source cybersecurity. Data refreshed daily.
        </p>
      </div>
      
      <div class="flex flex-col items-start gap-2 border-t border-surfaceBorder/30 pt-6">
        <p class="text-[11px] text-textSubtle/80 max-w-2xl leading-relaxed">
          Hosted on GitHub Pages (Microsoft Corp., USA) with Fastly as edge CDN. Migration to EU hosting is on the roadmap. Documented for transparency.
        </p>
        <div class="flex flex-wrap items-center gap-2 text-[11px] text-textSubtle/80 mt-1">
          <span class="font-medium text-textSubtle">Fabrizio Salmi</span> &middot; Sole Proprietorship &middot; P.IVA 03072120995 &middot; Genova, Italy
