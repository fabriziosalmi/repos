---
import Layout from "../layouts/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import DomainSection from "../components/DomainSection.astro";
import repositories from "../data/repositories.json";

// Type helper
interface Repo { [key: string]: any; }
const allRepos: Repo[] = repositories as Repo[];

// ─── Curation ───────────────────────────────────────────────────
// Repos excluded from the portfolio: internal scaffolds, profile repos,
// games, utility forks, supporting/CDN repos, archived items.
const EXCLUDED = new Set([
  // Bench scaffolds
  'gitoma-bench-blast', 'gitoma-bench-generation', 'gitoma-bench-ladder',
  'gitoma-bench-quality', 'gitoma-bench-scaffold-django', 'gitoma-bench-scaffold-mern',
  'gitoma-bench-triggers',
  // Meta / profile / self-referential
  'fabriziosalmi', 'repos',
  // Utility / internal / taps
  'gitignore', 'uglyfeed-cdn', 'homebrew-proxymate', 'shortlist-log',
  // Games
  'enjoy', 'github-games', 'crosswords',
  // Archived / legacy / old sites
  'iGPT', 'audiolibri.org_static', 'rivoluzioneinformatica-website',
  'transversal', 'audiolibri', 'audiolibri-editor',
  // Supporting / companion sites
  'certmate-website', 'domainsblacklists',
  // Old / low-signal / no-description
  'bootstrap-w3c-seo', 'WP-Search-Blacklist', 'gradios',
  'silence', 'tad', 'metatoken', 'metatoken-from-scratch',
  'rot', 'unuseful', 'web-kick', 'synapse-state', 'synapse-ng',
  // Italian-only or unclear purpose
  'extreme-content-detector',
  // Low-signal 0-star experiments
  'blockchain-poc', 'expire-api', 'dgrid', 'notransformers',
  'text-boundaries', 'zitto.net', 'ai-chatbot-encryption',
  'advanced-trading-framework',
  // Draconian V2 Curation - Privatize/Archive
  'betcracker', 'brutal-coding-tool', 'claude-code-brutal-edition',
  'freeundergroundtekno', 'b2v', 'drumate', 'linux', 'tubeconv',
  'awesomeness', 'synapseed', 'versiontracker', 'speedgate', 'repolizer',
  'secbeat', 'edge99', // NEVER MENTION THESE
  // Trim Other Projects
  'sci-fi', 'trinity', 'dnsmate'
]);

const repos = allRepos.filter(r => !EXCLUDED.has(r.name) && !r.archived);

// ─── Featured Projects ─────────────────────────────────────────
const FEATURED_NAMES = new Set(['certmate', 'caddy-waf', 'zion', 'llmproxy']);
const featured = Array.from(FEATURED_NAMES)
  .map(name => repos.find(r => r.name === name))
  .filter(Boolean) as Repo[];

// ─── Domain Assignments ─────────────────────────────────────────
const DOMAIN_SECURITY = new Set([
  'caddy-waf', 'certmate', 'patterns', 'wildbox', 'caddy-mib',
  'secure-proxy-manager', 'zion', 'caddy-adf', 'nginx-waf-ai',
  'limits', 'proxymate', 'netfence', 'caddy-feeds',
  'fqdn-model', 'domainmate', 'reverse-proxy-manager'
]);

const DOMAIN_INFRA = new Set([
  'proxmox-vm-autoscale', 'proxmox-lxc-autoscale', 'lws',
  'proxmox-lxc-autoscale-ml', 'proxmox-cluster-balancer',
  'zonecontrol', 'cf-box', 'wafcontrol',
  'dnscontrol-actions', 'cloudflare-backup-actions', 'websites-monitor',
  'rainlogs', 'proximity', 'proxima-ui', 'project-pegaprox',
  'mtls-cloudflare-aws', 'asn-api', 'k8s', 'test-aws-terraform'
]);

const DOMAIN_COMPLIANCE = new Set([
  'nis2-public', 'blacklists', 'aidlp'
]);

const DOMAIN_AI_DATA = new Set([
  'UglyFeed', 'vibe-check', 'csv-anonymizer', 'silicondev', 'alma', 'newsgator', 'DevGPT',
  'iamnotacoder', 'llm-benchmarks', 'navigator', 'gitoma', 'audiogen', 'ethical-ai'
]);

function domainRepos(domainSet: Set<string>) {
  // Filter out featured projects to avoid duplication
  return repos.filter(r => domainSet.has(r.name) && !FEATURED_NAMES.has(r.name)).sort((a, b) => (b.stars || 0) - (a.stars || 0));
}

const securityRepos = domainRepos(DOMAIN_SECURITY);
const infraRepos = domainRepos(DOMAIN_INFRA);
const complianceRepos = domainRepos(DOMAIN_COMPLIANCE);
const aiDataRepos = domainRepos(DOMAIN_AI_DATA);

// Catch repos not assigned to any domain (for "Other" section)
const assignedNames = new Set([...DOMAIN_SECURITY, ...DOMAIN_INFRA, ...DOMAIN_COMPLIANCE, ...DOMAIN_AI_DATA, ...FEATURED_NAMES]);
const otherRepos = repos
  .filter(r => !assignedNames.has(r.name))
  .sort((a, b) => (b.stars || 0) - (a.stars || 0));

// ─── Aggregate Stats ────────────────────────────────────────────
const totalStars = repos.reduce((s, r) => s + (r.stars || 0), 0);
const totalForks = repos.reduce((s, r) => s + (r.forks || 0), 0);
const totalRepos = repos.length;

// Language distribution
const langCount: Record<string, number> = {};
repos.forEach(r => { if (r.language) langCount[r.language] = (langCount[r.language] || 0) + 1; });
const topLangs = Object.entries(langCount).sort((a, b) => b[1] - a[1]).slice(0, 5);
const otherLangsCount = totalRepos - Object.values(langCount).reduce((a, b) => a + b, 0);
